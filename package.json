{
  "name": "wep-dashboard",
  "version": "1.1.2",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "ng": "ng",
    "start": "node dist/wep-dashboard/server/server.mjs",
    "build": "ng build --configuration production --optimization=true --source-map=false  --output-hashing=all --aot",
    "build:breeze": "ng build --configuration breeze --optimization=true --source-map=false  --output-hashing=all --aot",
    "build:deploy": "ng build --configuration deploy --optimization=true --source-map=false  --output-hashing=all --aot",
    "build:staging": "ng build --configuration staging --optimization=true --source-map=false  --output-hashing=all --aot",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:wep-dashboard": "node dist/wep-dashboard/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.15",
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/forms": "^21.2.14",
    "@angular/platform-browser": "^21.2.14",
    "@angular/platform-browser-dynamic": "^21.2.14",
    "@angular/platform-server": "^21.2.14",
    "@angular/router": "^21.2.14",
    "@angular/ssr": "^21.2.12",
    "@jsverse/transloco": "^7.6.1",
    "@lucide/angular": "^1.16.0",
    "@primeuix/themes": "^2.0.3",
    "chart.js": "^4.5.1",
    "express": "^4.22.2",
    "primeng": "^21.1.8",
    "rxjs": "~7.8.2",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.14",
    "@types/express": "^4.17.25",
    "@types/jasmine": "~5.1.15",
    "@types/node": "^18.19.130",
    "autoprefixer": "^10.5.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.15",
    "retry": "^0.13.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3"
  }
}
